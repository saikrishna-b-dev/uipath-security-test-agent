# ── UiPath Cloud ──────────────────────────────────────────────────────
UIPATH_BASE_URL=https://staging.uipath.com
UIPATH_ORG=hackathon26_154
UIPATH_TENANT=DefaultTenant
UIPATH_CLIENT_ID=your-oauth-client-id
UIPATH_CLIENT_SECRET=your-oauth-client-secret

# Test Manager project
TM_PROJECT_KEY=SSTO
TM_PROJECT_ID=

# ── OWASP ZAP ─────────────────────────────────────────────────────────
ZAP_HOST=localhost
ZAP_PORT=8080
ZAP_API_KEY=changeme
TARGET_URL=http://localhost:3000       # OWASP Juice Shop or your app

# ── Agent Runtime ─────────────────────────────────────────────────────
POLL_INTERVAL=30                       # seconds between monitor cycles
MAX_REPAIR_ATTEMPTS=3
HEALING_THRESHOLD=0.75                 # min confidence to attempt repair
REPORT_DIR=./reports
LOG_LEVEL=INFO
DRY_RUN=false                          # set true for testing without API writes
